# Admin dashboard API (Vite — rebuild after change)
VITE_API_BASE_URL=https://api.golivestreamers.com/api/v1

# HMAC signing — same secret as backend MOBILE_APP_SIGNING_SECRET
# App ID must be listed on server: MOBILE_APP_SIGNING_APP_IDS=golive-mobile,golive-admin
VITE_API_SIGNING_SECRET=your_long_random_secret_min_32_chars
VITE_API_SIGNING_APP_ID=golive-admin
